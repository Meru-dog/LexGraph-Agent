# LexGraph Agent — unified environment template (repo root)
# Copy this file to ".env" at the repository root and edit values.
# NOTE:
# - This is the source of truth for docker-compose + backend + frontend local dev.
# - backend/.env.example is a backend-only minimal subset to avoid duplicate drift.

# ── Core local LLM (default path) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-swallow:8b
FINE_TUNED_MODEL=lexgraph-legal:latest
JP_ADAPTER_MODEL=lexgraph-legal-jp:latest
US_ADAPTER_MODEL=lexgraph-legal-us:latest
DEFAULT_LLM_MODEL=ollama

# ── Optional cloud LLM (public/non-confidential data only) ───────────────────
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Optional vLLM endpoint (legacy/advanced) ─────────────────────────────────
LLAMA_ENDPOINT=http://localhost:8080
USE_VLLM=false

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lexgraph_dev

# ── Supabase (auth + pgvector + ragas score history) ─────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── JWT auth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ── Optional APIs ─────────────────────────────────────────────────────────────
EDINET_API_KEY=
EGOV_API_KEY=

# ── App operational settings ──────────────────────────────────────────────────
AUDIT_LOG_PATH=./data/audit.jsonl
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
