# LexGraph AI — Environment Variables Template
# Copy to .env and fill in your values

# ─── LLM — Gemini (Phase 2-3) ────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Model to use: gemini-1.5-pro (default) | gemini-1.5-flash (cheaper/faster)
GEMINI_MODEL=gemini-1.5-pro

# ─── LLM — Fine-tuned LLaMA (Phase 4+) ──────────────────────────────────────
# Set USE_VLLM=true and point LLAMA_ENDPOINT at your vLLM server
LLAMA_ENDPOINT=http://localhost:8080
USE_VLLM=false

# ─── Neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lexgraph_dev

# ─── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev
MINIO_BUCKET=lexgraph-docs

# ─── JWT Auth ────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ─── Audit Log ───────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=./data/audit.jsonl

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
