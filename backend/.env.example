# Backend-only local template (minimal).
# Prefer using the repo root ".env.example" as the canonical template.
# This file exists for backend-only runs (cd backend && cp .env.example .env).

# ── Local LLM ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-swallow:8b
FINE_TUNED_MODEL=lexgraph-legal:latest

# ── Optional Gemini (public/non-confidential data only) ─────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lexgraph_dev

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Auth + ops ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
AUDIT_LOG_PATH=./data/audit.jsonl
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Optional APIs ────────────────────────────────────────────────────────────
EDINET_API_KEY=
EGOV_API_KEY=
